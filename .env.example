# --- Option 1: Local Ollama (no API key) ---
# Set to use your local Ollama. Default: llama3.2 (also try llama3.2:latest)
OLLAMA_MODEL=llama3.2
# Or set USE_OLLAMA=1 to use Ollama with default model

# Optional: Ollama base URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# --- Option 2: Groq API (cloud) ---
# Get a free key at https://console.groq.com/
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.1-8b-instant

# --- Option 3: Hugging Face hosted inference (large models) ---
# Set LLM_PROVIDER=hf and provide token.
# LLM_PROVIDER=hf
# HF_TOKEN=your_huggingface_access_token
# HF_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct

# Optional provider selection override: ollama | groq | hf
# LLM_PROVIDER=ollama

# --- Optional spaCy enrichment ---
# SPACY_ENABLED=1
# SPACY_MODEL=en_core_web_sm
